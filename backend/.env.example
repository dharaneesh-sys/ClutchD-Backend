# ClutchD API — Local Development
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!
#
# For Docker development, use env.docker.example instead.

DATABASE_URL=postgresql+asyncpg://clutchd:clutchd@localhost:5432/clutchd
SYNC_DATABASE_URL=postgresql://clutchd:clutchd@localhost:5432/clutchd
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=dev-secret-key-do-not-use-in-production
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DEBUG=true

# Google OAuth (optional — leave empty to disable Google sign-in)
# Create OAuth 2.0 Web Client credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
