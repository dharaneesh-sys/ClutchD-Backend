# ClutchD API — Docker Environment Variables (Example)
#
# Copy this file to .env.docker and fill in your values.
# NEVER commit .env.docker to git!
#
# For local (non-Docker) development, use .env.example instead.

DATABASE_URL=postgresql+asyncpg://clutchd:clutchd@db:5432/clutchd
SYNC_DATABASE_URL=postgresql://clutchd:clutchd@db:5432/clutchd
REDIS_URL=redis://redis:6379/0
JWT_SECRET_KEY=change-me-to-a-random-64-char-hex-string
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DEV_AUTO_VERIFY_PROVIDERS=true
DEBUG=true
